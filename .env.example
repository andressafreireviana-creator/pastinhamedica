# Captura de lead do checklist — defina UMA das opções no painel do deploy (ex.: Vercel).

# Opção A — Web3Forms (mais simples e gratuito):
# Gere a chave em https://web3forms.com com o seu e-mail e cole abaixo.
WEB3FORMS_ACCESS_KEY=

# Opção B — Resend (alternativa):
# RESEND_API_KEY=re_xxxxxxxx
# LEAD_TO_EMAIL=seuemail@exemplo.com
# LEAD_FROM_EMAIL=Pastinha Médica <onboarding@resend.dev>

# (Opcional) URL final do site, usada em canonical/sitemap/robots:
# NEXT_PUBLIC_SITE_URL=https://seudominio.com.br

# ───────────────────────────────────────────────────────────────────────
# Aviso automático de editais (app/api/check-editais, agendado em vercel.json)
# Usa o mesmo e-mail acima (Web3Forms ou Resend).
#
# Protege o endpoint (o Vercel Cron envia este token automaticamente):
# CRON_SECRET=uma_senha_aleatoria_longa
#
# Armazenamento para detectar mudança (Vercel KV ou Upstash Redis — grátis).
# Aceita os nomes do Vercel KV OU do Upstash:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
